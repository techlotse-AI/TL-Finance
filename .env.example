# Pin deployments to a published versioned release tag. Do not use latest.
TL_FINANCE_IMAGE=techlotse/tl-finance
TL_FINANCE_MIGRATOR_IMAGE=techlotse/tl-finance-migrator
TL_FINANCE_VERSION=vX.Y.Z
POSTGRES_VERSION=16.14-alpine

POSTGRES_DB=tlfinance
POSTGRES_USER=tlfinance
POSTGRES_PASSWORD=replace-with-a-random-database-password
# URL-encode special characters from POSTGRES_PASSWORD in DATABASE_URL.
DATABASE_URL=postgresql://tlfinance:replace-with-a-random-database-password@db:5432/tlfinance?schema=public

# Bind to loopback when a TLS reverse proxy runs on the host.
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=3000
NEXT_PUBLIC_APP_URL=https://finance.example.com

AUDIT_IP_HASH_SECRET=replace-with-a-separate-random-secret-at-least-32-characters
RATE_LIMIT_HASH_SECRET=replace-with-another-separate-random-secret-at-least-32-characters
SCHEDULED_BACKUP_TOKEN=replace-with-a-random-scheduler-token-at-least-32-characters

# Reserve initial platform administration for this exact normalized email.
INSTANCE_ADMIN_EMAIL=admin@example.com
EMAIL_VERIFICATION_REQUIRED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=TL Finance <finance@example.com>

S3_BACKUP_ENDPOINT=
S3_BACKUP_REGION=
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=tl-finance
S3_BACKUP_ACCESS_KEY_ID=
S3_BACKUP_SECRET_ACCESS_KEY=
S3_BACKUP_FORCE_PATH_STYLE=false
S3_BACKUP_SERVER_SIDE_ENCRYPTION=AES256
S3_BACKUP_KMS_KEY_ID=
