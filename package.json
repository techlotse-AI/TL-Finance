{
  "name": "tl-finance",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "generate": "prisma generate",
    "dependencies:check": "npm ls --all",
    "compose:check": "node scripts/check-cloud-compose.mjs",
    "api:security:check": "node scripts/check-api-security.mjs",
    "migration:check": "node scripts/check-migrations.mjs",
    "platform:restore": "node scripts/restore-platform-backup.mjs",
    "version:check": "node scripts/check-release-version.mjs",
    "v0.4:readiness": "node scripts/check-v0.4-readiness.mjs",
    "security:audit": "npm audit --audit-level=critical",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:access": "vitest run src/lib/access",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1075.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "decimal.js": "10.6.0",
    "dotenv": "17.4.2",
    "lucide-react": "1.22.0",
    "next": "16.2.10",
    "nodemailer": "9.0.3",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.1.1",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.19",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "esbuild": "0.28.1",
    "postcss": "$postcss"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
